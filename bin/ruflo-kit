#!/usr/bin/env bash
# ============================================================================
# ruflo-kit — single entrypoint for the ruflo + Agentic QE setup/repair kit.
#
# Clone this repo once, then run it against ANY codebase path:
#
#   bin/ruflo-kit setup       /path/to/codebase     # fresh machine → proved stack (install+init+heal+proof)
#   bin/ruflo-kit status      /path/to/codebase     # one-screen truth (disk-derived; --json)
#   bin/ruflo-kit sync        /path/to/codebase     # one-verb heal (fix cascade; --dry-run)
#   bin/ruflo-kit proof       /path/to/codebase     # 15-probe disk-evidence proof, run twice (x2)
#   bin/ruflo-kit init        /path/to/codebase     # first-time bootstrap
#   bin/ruflo-kit session     /path/to/codebase     # per-session maintenance
#   bin/ruflo-kit health      /path/to/codebase     # growth-delta health check
#   bin/ruflo-kit fix-ruflo   /path/to/codebase     # repair ruflo MCP/AgentDB
#   bin/ruflo-kit fix-aqe     /path/to/codebase     # codify AQE hardening
#   bin/ruflo-kit fix-brain   /path/to/codebase     # register ruvnet-brain MCP server
#   bin/ruflo-kit fix-statusbar /path/to/codebase   # restore the statusline
#   bin/ruflo-kit upgrade     /path/to/codebase     # major ruflo version bump
#   bin/ruflo-kit verify-learning /path/to/codebase # read-only loop liveness (CI exit 1 if hollow)
#   bin/ruflo-kit fix-learning /path/to/codebase    # populate/unlock a hollow learning loop
#   bin/ruflo-kit bench       /path/to/codebase     # self-improvement bench (read-only)
#   bin/ruflo-kit harvest     /path/to/codebase     # replay AQE experiences
#   bin/ruflo-kit version                           # kit + ruflo + aqe versions
#   bin/ruflo-kit self-update                       # git pull the kit clone
#
# The target path is optional and defaults to $RUFLO_KIT_TARGET, else $(pwd).
# Flags (--dry-run/--force/--reactivate) may appear before or after the path.
# ============================================================================
set -uo pipefail

# Resolve KIT_DIR through symlinks so a global `ruflo-kit` on PATH (a symlink
# into the real clone) still finds lib/ assets/ tools/. macOS bash 3.2 has no
# `readlink -f`, so walk the link chain by hand (no GNU coreutils dependency).
_kit_resolve_dir() {
  local src="$1" dir
  while [ -h "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" 2>/dev/null && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" 2>/dev/null && pwd
}
KIT_DIR="$(cd "$(_kit_resolve_dir "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"

usage() {
  sed -n '2,/^# ===/p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//; s/^=.*//'
  cat <<EOF

Commands:
  setup          Fresh machine → proved working stack: install + init + heal + proof; --with-brain-kb
  status         One-screen truth (versions, sentinels, daemon, learning); --json
  sync           One-verb heal — run the fix cascade in order; --dry-run
  init           First-time bootstrap of a codebase (ruflo + AQE + AgentDB)
  session        Per-session maintenance (patches, daemon, verification)
  health         Growth-delta health check (CI-friendly exit code)
  proof          15-probe disk-evidence proof, run twice (x2) — exit 0 only when PROVED
  fix-ruflo      Diagnose + repair the ruflo / claude-flow MCP + AgentDB setup
  fix-aqe        Codify AQE-side hardening + install .claude helpers/commands
  fix-brain      Register the vendored ruvnet-brain search_ruvnet MCP server (MCP-only; --download to fetch the KB)
  dashboard      On-demand local web dashboard (foreground, read-only, 127.0.0.1; --port N; Ctrl-C stops)
  fix-statusbar  Restore the rich ruflo + Agentic QE v3 statusline
  upgrade        Major-version ruflo migration (stop daemon, bump, re-activate)
  verify-learning Read-only learning-loop liveness probes (CI-friendly exit code)
  fix-learning   Populate + unlock a hollow self-learning loop (idempotent, --dry-run)
  bench          Run the self-improvement bench (read-only)
  harvest        Replay AQE experiences into the ruflo substrate
  version        Show kit git sha + detected ruflo / agentic-qe versions
  self-update    git pull the kit clone (fast-forward only)
  help           Show this help

Run a command with -h for its own flags. Docs: $KIT_DIR/docs/
EOF
}

cmd="${1:-}"; shift 2>/dev/null || true
case "$cmd" in
  setup)         exec bash "$KIT_DIR/lib/setup.sh"          "$@" ;;
  status)        exec bash "$KIT_DIR/lib/status.sh"         "$@" ;;
  sync)          exec bash "$KIT_DIR/lib/sync.sh"           "$@" ;;
  proof)         exec bash "$KIT_DIR/lib/proof.sh"          "$@" ;;
  init)          exec bash "$KIT_DIR/lib/init.sh"           "$@" ;;
  fix-ruflo)     exec bash "$KIT_DIR/lib/fix-ruflo.sh"      "$@" ;;
  fix-aqe)       exec bash "$KIT_DIR/lib/fix-aqe.sh"        "$@" ;;
  fix-brain)     exec bash "$KIT_DIR/lib/fix-brain.sh"      "$@" ;;
  fix-statusbar) exec bash "$KIT_DIR/lib/fix-statusbar.sh"  "$@" ;;
  session|session-init) exec bash "$KIT_DIR/lib/session-init.sh" "$@" ;;
  health)        exec bash "$KIT_DIR/lib/health.sh"         "$@" ;;
  upgrade)       exec bash "$KIT_DIR/lib/upgrade.sh"        "$@" ;;
  verify-learning) exec bash "$KIT_DIR/lib/verify-learning.sh" "$@" ;;
  fix-learning)  exec bash "$KIT_DIR/lib/fix-learning.sh"   "$@" ;;
  bench)
    # tools/ operate on the target's runtime DBs via cwd → cd into the target.
    t="${1:-${RUFLO_KIT_TARGET:-$(pwd)}}"; [[ "$t" == --* ]] && t="${RUFLO_KIT_TARGET:-$(pwd)}" || shift 2>/dev/null || true
    ( cd "$t" 2>/dev/null || cd "$(pwd)"; exec node "$KIT_DIR/tools/selfimprove-bench.cjs" "$@" ) ;;
  dashboard)
    # On-demand LOCAL dashboard (DASHBOARD-V1): foreground, read-only,
    # 127.0.0.1-only, Ctrl-C to stop. Never detaches, never billed.
    t="${1:-${RUFLO_KIT_TARGET:-$(pwd)}}"; [[ "$t" == --* ]] && t="${RUFLO_KIT_TARGET:-$(pwd)}" || shift 2>/dev/null || true
    ( cd "$t" 2>/dev/null || cd "$(pwd)"; exec node "$KIT_DIR/tools/dashboard.cjs" "$@" ) ;;
  harvest)
    t="${1:-${RUFLO_KIT_TARGET:-$(pwd)}}"; [[ "$t" == --* ]] && t="${RUFLO_KIT_TARGET:-$(pwd)}" || shift 2>/dev/null || true
    ( cd "$t" 2>/dev/null || cd "$(pwd)"; exec node "$KIT_DIR/tools/aqe-harvest.cjs" "$@" ) ;;
  version|--version|-v)
    kit_sha="$(git -C "$KIT_DIR" rev-parse --short HEAD 2>/dev/null || echo '?')"
    kit_date="$(git -C "$KIT_DIR" log -1 --format=%cd --date=short 2>/dev/null || echo '?')"
    echo "ruflo-kit   $kit_sha ($kit_date)   $KIT_DIR"
    if command -v ruflo >/dev/null 2>&1; then
      rv="$(node -p "require('$(npm root -g 2>/dev/null)/ruflo/package.json').version" 2>/dev/null || echo '?')"
      echo "ruflo       $rv (global)"
    else echo "ruflo       not installed (npm i -g ruflo)"; fi
    av="$(node -p "require('$(npm root -g 2>/dev/null)/agentic-qe/package.json').version" 2>/dev/null || echo 'not installed')"
    echo "agentic-qe  $av (global)" ;;
  self-update)
    [ -d "$KIT_DIR/.git" ] || { echo "ruflo-kit: $KIT_DIR is not a git clone — re-run the installer"; exit 1; }
    echo "Updating kit at $KIT_DIR …"
    git -C "$KIT_DIR" pull --ff-only && echo "Now at $(git -C "$KIT_DIR" rev-parse --short HEAD)."
    echo "Reminder: after any global ruflo bump, run 'ruflo-kit fix-ruflo <target>' + restart the daemon (see docs Patch 44)." ;;
  "")
    # Bare invocation: lead with a compact status hint (against $(pwd)), then usage.
    if [ -f "$KIT_DIR/lib/status.sh" ]; then
      echo "ruflo-kit — current state ($(pwd)):"
      bash "$KIT_DIR/lib/status.sh" "$(pwd)" --hints 2>/dev/null || true
      echo ""
    fi
    usage ;;
  help|-h|--help) usage ;;
  *) echo "ruflo-kit: unknown command '$cmd'"; echo; usage; exit 1 ;;
esac
